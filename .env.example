# ───── App ─────
NODE_ENV=production
PORT=3045
FRONTEND_URL=https://your-domain.example.com

# ───── PostgreSQL ─────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=triptastic
DB_USER=triptastic_user
DB_PASSWORD=change_me
DB_SSL=false
DB_POOL_MAX=20
DB_LOG_QUERIES=false

# Postgres superuser used ONLY by migration/setup_database.sh
PG_SUPER_USER=postgres

# ───── Auth ─────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ───── Storage ─────
UPLOAD_DIR=./server/uploads
MAX_UPLOAD_MB=20

# ───── SMS / OTP (BulkSMSBD) ─────
SMS_API_KEY=
SMS_SENDER_ID=

# ───── Email (SMTP) ─────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ───── Online Payment (SSLCommerz) ─────
SSLCZ_STORE_ID=
SSLCZ_STORE_PASSWORD=
SSLCZ_IS_LIVE=false

# ───── Backup (optional Google Drive rclone) ─────
BACKUP_REMOTE=
BACKUP_RETENTION_DAYS=30
